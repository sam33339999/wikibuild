# WikiBuilder configuration. Copy to .env and edit:
#   cp .env.example .env
#
# .env is loaded automatically by the app (godotenv) and by docker compose.
# Real environment variables take precedence over values here.

# ---- PostgreSQL (docker compose service + app connection) ----
# These three drive the compose Postgres container.
POSTGRES_USER=wikibuild
POSTGRES_PASSWORD=wikibuild
POSTGRES_DB=wikibuild
POSTGRES_PORT=5432

# Connection string the app uses. Must match POSTGRES_* above.
DATABASE_URL=postgres://wikibuild:wikibuild@localhost:5432/wikibuild?sslmode=disable

# ---- App ----
# Bind address. 127.0.0.1 = localhost only (safe default; expose via a reverse
# proxy that terminates TLS). Set to 0.0.0.0 to listen on all interfaces.
WIKIBUILD_HOST=127.0.0.1
WIKIBUILD_PORT=8080

# Admin account, created on first start if it does not exist.
WIKIBUILD_ADMIN_USER=admin
WIKIBUILD_ADMIN_PASS=changeme

# HMAC key for signing session cookies. Use >= 32 random characters.
# Generate one, e.g.:  openssl rand -hex 32
WIKIBUILD_SESSION_SECRET=replace-with-a-long-random-secret-value

# Directory for uploaded HTML content (created at runtime).
WIKIBUILD_CONTENT_DIR=./content/uploads

# Site-wide default password for protected articles (empty = no default).
WIKIBUILD_DEFAULT_PROTECTED_PASS=
